{
  "description": "Plugin-bundled mirror of the project Codex hooks. Project .codex/hooks.json is the active local source; this file lets the plugin expose the same lifecycle surface.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/agent/target/debug/agent guard",
            "timeout": 5,
            "statusMessage": "Checking destructive command policy"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/agent/target/debug/agent codex stop",
            "timeout": 30,
            "statusMessage": "Checking meta workspace handoff"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$(git rev-parse --show-toplevel)/agent/target/debug/agent codex stop",
            "timeout": 30,
            "statusMessage": "Checking meta subagent handoff"
          }
        ]
      }
    ]
  }
}
