{
  "statusLine": {
    "type": "command",
    "command": "bash \"${CLAUDE_PROJECT_DIR}/.claude/statusline-command.sh\""
  },
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "meta context 2>/dev/null",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PROJECT_DIR}/agent/target/debug/agent\" guard",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "meta context 2>/dev/null",
            "timeout": 10,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "git kb service status --quiet 2>/dev/null || git kb service start 2>/dev/null",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "vox \"Done.\"",
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git push:*)",
      "Bash(meta git push:*)",
      "Bash(git -C * push:*)"
    ]
  }
}
