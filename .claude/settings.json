{
  "statusLine": {
    "type": "command",
    "command": "bash \"${CLAUDE_PROJECT_DIR}/.claude/statusline-command.sh\""
  },
  "hooks": {
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "meta context 2>/dev/null",
            "timeout": 10,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.claude/hooks/hf-checkpoint.sh\"",
            "timeout": 15,
            "type": "command"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/block-cherry-pick.sh"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "\"${CLAUDE_PROJECT_DIR}/agent/target/debug/agent\" guard",
            "timeout": 5,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "meta context 2>/dev/null",
            "timeout": 10,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "pgrep -f 'git-kb serve' >/dev/null 2>&1 || (nohup git kb serve >/dev/null 2>&1 &)",
            "timeout": 10,
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "vox \"Done.\"",
            "type": "command"
          }
        ],
        "matcher": ""
      },
      {
        "hooks": [
          {
            "command": "bash \"${CLAUDE_PROJECT_DIR}/.claude/hooks/hf-checkpoint.sh\"",
            "timeout": 15,
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git push:*)",
      "Bash(meta git push:*)",
      "Bash(git -C * push:*)"
    ]
  }
}
